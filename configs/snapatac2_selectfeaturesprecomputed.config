process {
    withName: '.*SNAPATAC2_SELECTFEATURESPRECOMPUTED' {
        ext.args = {
            [
                "--groupby leiden_selectfeatures",
                "--n-iter 1",
                "--n-features ${params.atac.tile.n_features}",
                "--subset-selected"
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "normal"
        memory     = {
            def sizeGb = h5ad.size() / (1024d * 1024d * 1024d)
            def adjustedGb = sizeGb + Math.max(0d, sizeGb - 80d)
            ((Math.ceil(adjustedGb) as long).GB) + 128.GB + 64.GB * (task.attempt - 1)
        }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/features/" },
            overwrite: true
        ]
    }
}
