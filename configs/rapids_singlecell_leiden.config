process {
    withName: '.*ATAC:RAPIDS_SINGLECELL_LEIDEN' {
        ext.args = {
            [
                "--resolution ${params.leiden.resolution}",
                "--random-state ${params.random_state}",
                "--theta ${params.leiden.theta}",
                "--key-added ${params.leiden.key_added}",
                "--n-iterations ${params.leiden.n_iterations}",
                "--use-weights ${params.leiden.use_weights}",
                "--use-dask ${params.leiden.use_dask}",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "gpu-normal"
        clusterOptions      = ' -gpu "mode=shared:j_exclusive=no:gmem=8000:num=1"'
        containerOptions    = '--nv'
        memory     = { ((Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long).GB) + 8.GB + 16.GB * (task.attempt - 1) }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/leiden/" },
            overwrite: true
        ]
    }
}
