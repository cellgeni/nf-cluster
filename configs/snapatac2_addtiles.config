process {
    withName: '.*SNAPATAC2_ADDTILES' {
        ext.args = {
            [
                "--bin-size ${params.atac.tile.bin_size}",
                params.atac.tile.exclude_chroms instanceof List ? "--exclude-chroms ${params.atac.tile.exclude_chroms.join(' --exclude-chroms ')}" : "",
                params.atac.tile.min_frag_size != null ? "--min-frag-size ${params.atac.tile.min_frag_size}" : "",
                params.atac.tile.max_frag_size != null ? "--max-frag-size ${params.atac.tile.max_frag_size}" : "",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "normal"
        memory     = { ((Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long).GB) + 4.GB + 16.GB * (task.attempt - 1) }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/tiles/" },
            overwrite: true
        ]
    }
}
