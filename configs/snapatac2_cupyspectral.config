process {
    withName: '.*SNAPATAC2_CUPYSPECTRAL' {
        ext.args = {
            [
                "--n-comps ${params.atac.spectral.n_comps}",
                "--features ${params.atac.selected_features}",
                "--random-state ${params.random_state}",
                params.atac.spectral.weighted_by_sd ? "--weighted-by-sd" : "--no-weighted-by-sd",
                params.atac.spectral.feature_weights instanceof List && params.atac.spectral.feature_weights ? "--feature-weights ${params.atac.spectral.feature_weights.join(' --feature-weights ')}" : "",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "gpu-normal"
        memory     = { fileSizeInGB(h5ad) + 16.GB + 64.GB * (task.attempt - 1) }
        clusterOptions      = {
            def sizeGbRoundedUp = Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long
            def gmemMb = Math.min((sizeGbRoundedUp + 2L) * 1024L, 80L * 1024L)
            " -gpu \"mode=shared:j_exclusive=no:gmem=${gmemMb}:num=1:gmodel=NVIDIAA100_SXM4_80GB\""
        }
        containerOptions    = '--nv'
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/spectral/" },
            overwrite: true
        ]
    }

    withName: '.*SNAPATAC2_CUPYSPECTRAL_MOSTACCESSIBLE' {
        ext.args = {
            [
                "--n-comps ${params.atac.spectral.n_comps}",
                "--features selected",
                "--random-state ${params.random_state}",
                params.atac.spectral.weighted_by_sd ? "--weighted-by-sd" : "--no-weighted-by-sd",
                params.atac.spectral.feature_weights instanceof List && params.atac.spectral.feature_weights ? "--feature-weights ${params.atac.spectral.feature_weights.join(' --feature-weights ')}" : "",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "gpu-normal"
        memory     = { fileSizeInGB(h5ad) + 16.GB + 64.GB * (task.attempt - 1) }
        clusterOptions      = {
            def sizeGbRoundedUp = Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long
            def gmemMb = Math.min((sizeGbRoundedUp + 2L) * 1024L, 80L * 1024L)
            " -gpu \"mode=shared:j_exclusive=no:gmem=${gmemMb}:num=1:gmodel=NVIDIAA100_SXM4_80GB\""
        }
        containerOptions    = '--nv'
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/spectral/" },
            overwrite: true
        ]
    }
}
