process {
    withName: '.*ATAC:SCANPY_LEIDEN_SELECTFEATURES' {
        ext.args = {
            [
                "--resolution 0.05",
                "--random-state ${params.random_state}",
                "--key-added leiden_selectfeatures",
                "--neighbors-key neighbors_selectfeatures",
                "--use-weights true",
                "--n-iterations 1",
                "--flavor leidenalg",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "long"
        memory     = {
            def sizeGb = h5ad.size() / (1024d * 1024d * 1024d)
            def adjustedGb = sizeGb + Math.max(0d, sizeGb - 80d)
            ((Math.ceil(adjustedGb) as long).GB) + 32.GB + 64.GB * (task.attempt - 1)
        }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/leiden_selectfeatures/" },
            overwrite: true
        ]
    }
}
