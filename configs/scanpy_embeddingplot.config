process {
    withName: '.*ATAC:SCANPY_EMBEDDING_PLOT' {
        ext.args = {
            [
                "--basis ${params.embeddingplot.basis}",
                params.embeddingplot.color instanceof List ? "--color ${params.embeddingplot.color.join(' --color ')}" : "",
                "--legend-loc \"${params.embeddingplot.legend_loc}\"",
                "--ncols ${params.embeddingplot.ncols}",
                "--dpi ${params.embeddingplot.dpi}",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "normal"
        memory     = { ((Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long).GB) + 4.GB + 8.GB * (task.attempt - 1) }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/plots/embedding/" },
            overwrite: true
        ]
    }
}
