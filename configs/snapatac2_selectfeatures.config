process {
    withName: '.*SNAPATAC2_SELECTFEATURES' {
        ext.args = {
            [
                "--n-features ${params.atac.tile_n_features}",
                "--filter-lower-quantile ${params.atac.tile_filter_lower_quantile}",
                "--filter-upper-quantile ${params.atac.tile_filter_upper_quantile}",
                params.atac.subset_features ? "--subset-features" : "",
            ].findAll { v -> v }.join(' ')
        }
        cpus       = 1
        queue      = "normal"
        memory     = { ((Math.ceil(h5ad.size() / (1024d * 1024d * 1024d)) as long).GB) + 4.GB + 16.GB * (task.attempt - 1) }
        publishDir = [
            mode     : 'link',
            path     : { "${params.outdir}/h5ad/features/" },
            overwrite: true
        ]
    }
}
